ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENAI_BASE_URL=

# Hidden feature: when set to 1/true/yes/on, the UI forces the operator to read and accept a
# risk/responsibility disclaimer before starting an engagement or bypassing the approval gate.
# Leave blank/unset to disable. (A real shell environment variable overrides this file.)
SPAIDER_REQUIRE_DISCLAIMER=

# Production hardening: set to 1/true/yes/on when serving SPAIDER over HTTPS so the login-session
# cookie is marked `Secure` (never sent over plaintext http). Leave blank for local http development.
SPAIDER_SECURE_COOKIES=
